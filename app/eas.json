{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "env": {
        "EXPO_USE_POD_REPO_UPDATE": "1"
      },
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "env": {
        "EXPO_USE_POD_REPO_UPDATE": "1"
      },
      "developmentClient": false,
      "distribution": "internal"
    },
    "device": {
      "env": {
        "EXPO_USE_POD_REPO_UPDATE": "1"
      },
      "developmentClient": false,
      "distribution": "internal"
    },
    "production": {
      "env": {
        "EXPO_USE_POD_REPO_UPDATE": "1"
      },
      "distribution": "store",
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
