{
  "expo": {
    "name": "Rhema Daily",
    "slug": "rhema",
    "scheme": "wordflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#E8503A"
    },
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.odih.rhema",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Rhema Daily uses the microphone to record sermons so we can transcribe and summarize them (e.g., recording a sermon for notes).",
        "NSPhotoLibraryUsageDescription": "Rhema Daily needs access to your photo library to save generated content."
      }
    },
    "android": {
      "package": "com.odih.rhema",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Rhema Daily to use your microphone to record sermons for transcription."
        }
      ],
      "expo-notifications",
      "@react-native-community/datetimepicker",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.REPLACE_ME"
        }
      ],
      "expo-font",
      "expo-asset"
    ],
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "owner": "odih",
    "extra": {
      "eas": {
        "projectId": "b9182640-8da5-4379-909a-53ab74c46bcd"
      }
    }
  }
}
